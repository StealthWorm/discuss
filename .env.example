# Versioned environment template (no real secrets)
# Copy to .env.local for local development.

# App database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/discuss?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/discuss?schema=public"

# GitHub OAuth (local dev / CI)
GITHUB_CLIENT_ID="replace-me"
GITHUB_CLIENT_SECRET="replace-me"

# NextAuth/Auth.js secret (generate a long random value)
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST="true"
AUTH_URL="http://localhost:3000"
