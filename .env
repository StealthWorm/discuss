# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Local Postgres for app runtime (Prisma Client adapter)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/discuss?schema=public"

# Local Postgres direct connection for Prisma Migrate
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/discuss?schema=public"

# OAuth / auth placeholders (safe to keep versioned)
GITHUB_CLIENT_ID="replace-me"
GITHUB_CLIENT_SECRET="replace-me"
AUTH_SECRET="replace-with-a-long-random-secret"